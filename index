<script>
/* ============================ Supabase client ============================ */
let sb=null, session=null, currentEmail='', accessToken='';
const configured = SUPABASE_URL && SUPABASE_ANON_KEY && !SUPABASE_URL.startsWith('PASTE');
if(configured){ sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY); }
else { document.getElementById('configWarn').classList.remove('hidden'); }

const CATEGORIES=['Acquisition / research','Tenant / guest communication','Maintenance & repairs',
  'Cleaning / turnover','Bookkeeping & finances','Marketing & advertising','Property management',
  'Travel','Education & research','Legal & admin','Other'];
let STATE={entries:[],properties:[],personSettings:{},raw:{properties:[],entries:[],person_settings:[]}};
let currentYear=new Date().getFullYear();
let currentUserFilter='';           // '' = whole team, else an email (dashboard)
let charts={};
let dirty=false, autoTimer=null, sessionStarted=false;
const esc=s=>(s||'').replace(/[&<>"]/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c]));
const fmtH=h=>(Math.round((+h||0)*10)/10).toString();
const propById=id=>STATE.properties.find(p=>p.id===id);
const shortUser=e=>e?e.split('@')[0]:'';
function toast(m){const t=document.getElementById('toast');t.textContent=m;t.classList.add('show');setTimeout(()=>t.classList.remove('show'),2400);}
function setSaveState(s){document.getElementById('saveState').textContent=s;}
function safeUuid(){return (crypto.randomUUID?crypto.randomUUID():Date.now().toString(36)+Math.random().toString(36).slice(2));}

/* ============================ Auth ============================ */
let signupMode=false;
function renderAuthMode(){
  document.getElementById('authTitle').textContent=signupMode?'Create account':'Sign in';
  document.getElementById('authBtn').textContent=signupMode?'Create account':'Sign in';
  document.getElementById('authToggle').innerHTML=signupMode
    ? 'Already have an account? <a id="toggleLink">Sign in</a>'
    : 'New here? <a id="toggleLink">Create an account</a>';
  document.getElementById('toggleLink').onclick=()=>{signupMode=!signupMode;renderAuthMode();};
}
async function doAuth(){
  if(!configured)return;
  const email=document.getElementById('email').value.trim();
  const pass=document.getElementById('pass').value;
  const err=document.getElementById('authErr');err.textContent='';
  if(!email||!pass){err.textContent='Enter email and password.';return;}
  document.getElementById('authBtn').disabled=true;
  try{
    let res=signupMode?await sb.auth.signUp({email,password:pass}):await sb.auth.signInWithPassword({email,password:pass});
    if(res.error){err.textContent=res.error.message;return;}
    if(signupMode && !res.data.session){err.textContent='Account created. If email confirmation is on, check your inbox, then sign in.';signupMode=false;renderAuthMode();return;}
  }catch(e){err.textContent=String(e.message||e);}
  finally{document.getElementById('authBtn').disabled=false;}
}
async function onSession(s){
  session=s;
  if(s){
    currentEmail=s.user.email; accessToken=s.access_token||'';
    document.getElementById('auth').classList.add('hidden');
    document.getElementById('app').classList.remove('hidden');
    document.getElementById('whoami').textContent=currentEmail;
    await boot();
    if(!sessionStarted){sessionStarted=true;subscribeRealtime();weeklyBackupCheck();}
  } else {
    document.getElementById('app').classList.add('hidden');
    document.getElementById('auth').classList.remove('hidden');
    sessionStarted=false;
  }
}

/* ============================ Data layer ============================ */
function mapEntry(r){return {id:r.id,date:r.entry_date,propertyId:r.property_id,category:r.category,hours:Number(r.hours),
  activity:r.activity,notes:r.notes,attachmentPath:r.attachment_path,by:r.created_by_email||''};}
function mapProp(r){return {id:r.id,name:r.name,address:r.address,type:r.type,othersHours:Number(r.others_hours)};}
async function boot(){
  const [{data:props},{data:ents},{data:ps}]=await Promise.all([
    sb.from('properties').select('*').order('name'),
    sb.from('entries').select('*').order('entry_date',{ascending:false}),
    sb.from('person_settings').select('*')
  ]);
  STATE.raw={properties:props||[],entries:ents||[],person_settings:ps||[]};
  STATE.properties=(props||[]).map(mapProp);
  STATE.entries=(ents||[]).map(mapEntry);
  STATE.personSettings={};(ps||[]).forEach(r=>STATE.personSettings[r.email+'|'+r.year]=Number(r.other_hours));
  buildYearOptions();renderAll();
}
function markDirty(){dirty=true;setSaveState('unsaved backup pending…');clearTimeout(autoTimer);autoTimer=setTimeout(()=>takeSnapshot('auto'),30000);}
async function addOrUpdateEntry(rec,file,oldPath){
  let attachment_path=oldPath||null;
  if(file){
    const path=safeUuid()+'-'+file.name.replace(/[^\w.\-]+/g,'_');
    const up=await sb.storage.from('evidence').upload(path,file);
    if(up.error){toast('Attachment upload failed: '+up.error.message);}
    else{ if(oldPath)await sb.storage.from('evidence').remove([oldPath]); attachment_path=path; }
  }
  const base={entry_date:rec.date,property_id:rec.propertyId||null,category:rec.category,hours:rec.hours,
    activity:rec.activity,notes:rec.notes,attachment_path};
  let res;
  if(rec.id){res=await sb.from('entries').update(base).eq('id',rec.id);}
  else{res=await sb.from('entries').insert(Object.assign({},base,{created_by_email:currentEmail}));}
  if(res.error){toast('Save failed: '+res.error.message);return false;}
  markDirty();await boot();return true;
}
async function deleteEntry(e){
  if(e.attachmentPath)await sb.storage.from('evidence').remove([e.attachmentPath]);
  const res=await sb.from('entries').delete().eq('id',e.id);
  if(res.error){toast('Delete failed: '+res.error.message);return;}
  markDirty();await boot();
}
async function saveProperty(rec){
  const payload={name:rec.name,address:rec.address,type:rec.type,others_hours:rec.othersHours};
  let res=rec.id?await sb.from('properties').update(payload).eq('id',rec.id):await sb.from('properties').insert(payload);
  if(res.error){toast('Save failed: '+res.error.message);return false;}
  markDirty();await boot();return true;
}
async function deleteProperty(id){
  const res=await sb.from('properties').delete().eq('id',id);
  if(res.error){toast('Delete failed: '+res.error.message);return;}
  markDirty();await boot();
}
async function savePersonSetting(email,year,hours){
  const res=await sb.from('person_settings').upsert({email,year,other_hours:hours});
  if(res.error){toast('Save failed: '+res.error.message);return;}
  STATE.personSettings[email+'|'+year]=hours;markDirty();renderDashboard();renderSettings();toast('Saved.');
}
async function viewAttachment(path){
  const {data,error}=await sb.storage.from('evidence').createSignedUrl(path,120);
  if(error){toast('Could not open file: '+error.message);return;}
  window.open(data.signedUrl,'_blank');
}
let rtTimer=null;
function subscribeRealtime(){
  if(!sb.channel)return;
  sb.channel('shared')
    .on('postgres_changes',{event:'*',schema:'public',table:'entries'},()=>debouncedReload())
    .on('postgres_changes',{event:'*',schema:'public',table:'properties'},()=>debouncedReload())
    .on('postgres_changes',{event:'*',schema:'public',table:'person_settings'},()=>debouncedReload())
    .subscribe();
}
function debouncedReload(){clearTimeout(rtTimer);rtTimer=setTimeout(()=>boot(),500);}

/* ============================ Snapshots / backup ============================ */
async function takeSnapshot(reason){
  if(!sb||!session)return {error:'no session'};
  const [{data:props},{data:ents},{data:ps}]=await Promise.all([
    sb.from('properties').select('*'),sb.from('entries').select('*'),sb.from('person_settings').select('*')]);
  const data={properties:props||[],entries:ents||[],person_settings:ps||[]};
  const res=await sb.from('snapshots').insert({created_by_email:currentEmail,reason,data});
  if(!res.error){dirty=false;setSaveState('backed up '+new Date().toLocaleTimeString());pruneAuto();}
  return res;
}
async function pruneAuto(){
  const {data}=await sb.from('snapshots').select('id,created_at').eq('reason','auto').order('created_at',{ascending:true});
  if(data && data.length>40){const extra=data.slice(0,data.length-40).map(x=>x.id);await sb.from('snapshots').delete().in('id',extra);}
}
async function weeklyBackupCheck(){
  const {data}=await sb.from('snapshots').select('created_at').order('created_at',{ascending:false}).limit(1);
  const last=data&&data[0]?new Date(data[0].created_at).getTime():0;
  if(Date.now()-last > 7*24*3600*1000) takeSnapshot('weekly-auto');
}
// Forced backup when the tab is hidden/closed (best-effort, uses keepalive).
function flushExit(){
  if(!dirty||!session||typeof fetch!=='function')return;
  try{
    fetch(SUPABASE_URL+'/rest/v1/snapshots',{method:'POST',keepalive:true,
      headers:{'apikey':SUPABASE_ANON_KEY,'Authorization':'Bearer '+accessToken,'Content-Type':'application/json','Prefer':'return=minimal'},
      body:JSON.stringify({created_by_email:currentEmail,reason:'exit',data:STATE.raw})});
    dirty=false;
  }catch(e){}
}
window.addEventListener('visibilitychange',()=>{if(document.visibilityState==='hidden')flushExit();});
window.addEventListener('pagehide',flushExit);

async function renderHistory(){
  document.getElementById('histEmpty').textContent='Loading…';
  const {data,error}=await sb.from('snapshots').select('id,created_at,created_by_email,reason').order('created_at',{ascending:false}).limit(200);
  const body=document.getElementById('histBody');
  if(error){document.getElementById('histEmpty').textContent='Could not load history.';body.innerHTML='';return;}
  document.getElementById('histEmpty').classList.toggle('hidden',(data||[]).length>0);
  if((data||[]).length===0)document.getElementById('histEmpty').textContent='No snapshots yet.';
  body.innerHTML=(data||[]).map(function(s){
    const r=(s.reason||'auto').replace('weekly-auto','weekly').replace('sign-out','signout').replace('before-restore','restore');
    const label=({weekly:'Weekly auto',auto:'Auto (after edits)',signout:'Sign-out',exit:'App closed',manual:'Manual',restore:'Before a restore'})[r]||s.reason;
    return '<tr><td>'+new Date(s.created_at).toLocaleString()+'</td><td class="muted">'+esc(shortUser(s.created_by_email))+'</td>'+
      '<td><span class="reason '+r+'">'+label+'</span></td>'+
      '<td style="white-space:nowrap"><button class="btn ghost sm" data-dl="'+s.id+'">Download</button> '+
      '<button class="btn ghost sm" data-restore="'+s.id+'">Restore</button></td></tr>';}).join('');
}
async function downloadSnapshot(id){
  const {data,error}=await sb.from('snapshots').select('created_at,data').eq('id',id).single();
  if(error){toast('Could not load snapshot');return;}
  const u=URL.createObjectURL(new Blob([JSON.stringify(data.data,null,2)],{type:'application/json'}));
  const a=document.createElement('a');a.href=u;a.download='rep-hours-snapshot-'+(data.created_at||'').slice(0,10)+'.json';a.click();URL.revokeObjectURL(u);
}
async function restoreSnapshot(id){
  if(!confirm('Restore will REPLACE all current properties, hours, and settings with this snapshot for everyone. A safety backup is taken first. Continue?'))return;
  toast('Restoring…');
  await takeSnapshot('before-restore');
  const {data:snap,error}=await sb.from('snapshots').select('data').eq('id',id).single();
  if(error){toast('Could not load snapshot');return;}
  const d=snap.data||{};
  await sb.from('entries').delete().not('id','is',null);
  await sb.from('properties').delete().not('id','is',null);
  await sb.from('person_settings').delete().not('email','is',null);
  if((d.properties||[]).length)await sb.from('properties').insert(d.properties);
  if((d.entries||[]).length){const ents=d.entries.map(e=>{const c=Object.assign({},e);delete c.created_by;return c;});await sb.from('entries').insert(ents);}
  if((d.person_settings||[]).length)await sb.from('person_settings').insert(d.person_settings);
  await boot();renderHistory();toast('Restored.');
}

/* ============================ Rendering ============================ */
function entriesForYear(){return STATE.entries.filter(e=>new Date(e.date).getFullYear()===currentYear);}
function knownUsers(){const set=new Set();STATE.entries.forEach(e=>{if(e.by)set.add(e.by);});if(currentEmail)set.add(currentEmail);return [...set].sort();}
function buildYearOptions(){
  const yrs=new Set(STATE.entries.map(e=>new Date(e.date).getFullYear()));
  yrs.add(new Date().getFullYear());yrs.add(currentYear);
  const sel=document.getElementById('yearSelect');
  sel.innerHTML=[...yrs].sort((a,b)=>b-a).map(y=>'<option value="'+y+'">'+y+'</option>').join('');
  sel.value=currentYear;
}
function renderAll(){renderDashboard();renderLog();renderProperties();renderSettings();}

function renderDashboard(){
  document.getElementById('dashYear').textContent=currentYear;
  // user filter dropdown
  const uf=document.getElementById('userFilter');
  const users=knownUsers();
  if(currentUserFilter && !users.includes(currentUserFilter))currentUserFilter='';
  uf.innerHTML='<option value="">Whole team</option>'+users.map(u=>'<option value="'+esc(u)+'" '+(u===currentUserFilter?'selected':'')+'>'+esc(u)+'</option>').join('');
  uf.value=currentUserFilter;

  let es=entriesForYear();
  if(currentUserFilter)es=es.filter(e=>e.by===currentUserFilter);
  const total=es.reduce((s,e)=>s+e.hours,0);
  const days=new Set(es.map(e=>e.date)).size;
  const strProps=STATE.properties.filter(p=>p.type==='STR');
  const strHours=es.filter(e=>{const p=propById(e.propertyId);return p&&p.type==='STR';}).reduce((s,e)=>s+e.hours,0);
  const single=!!currentUserFilter;
  const otherH=single?Number(STATE.personSettings[currentUserFilter+'|'+currentYear]||0):0;

  const nonReVal=single?fmtH(otherH):'—';
  const nonReSub=single?((total>0&&otherH<total)?'RE is majority':'Set in Settings for test #2'):'Pick a person to test';
  document.getElementById('statCards').innerHTML=
    statCard('RE hours'+(single?' ('+shortUser(currentUserFilter)+')':' (team)'),fmtH(total),'across '+es.length+' entries, '+days+' active days',Math.min(100,total/750*100),total>750?'--green':'--accent2')+
    statCard('Toward 750-hr REPS',(total>=750?'Met':fmtH(Math.max(0,750-total))+' to go'),total>=750?'Threshold met':fmtH(total)+' / 750 hrs',Math.min(100,total/750*100),total>=750?'--green':'--accent2')+
    statCard('Short-term rental hours',fmtH(strHours),strProps.length+' STR '+(strProps.length===1?'property':'properties'),Math.min(100,strHours/500*100),'--accent2')+
    statCard('Non-RE work hours',nonReVal,nonReSub,(single&&(otherH+total)>0)?Math.min(100,otherH/(otherH+total)*100):0,(single&&otherH<total&&total>0)?'--green':'--amber');

  const t1=total>750, t2=single && total>otherH && total>0;
  document.getElementById('repsTests').innerHTML=
    testRow('More than 750 hours','In real property trades/businesses',t1,fmtH(total)+' hrs')+
    testRow('More than half your working time',single?'RE hours vs. other work hours':'Select a person above',t2,single?(otherH>0?(fmtH(total)+' vs '+fmtH(otherH)+' hrs'):'set other hrs'):'per-person',!single)+
    testRow('Overall REPS',single?'Both tests must pass':'Team total is not a REPS test',single&&t1&&t2,single?(t1&&t2?'Likely qualifies':'Not yet'):'pick a person',!single);

  const strBox=document.getElementById('strTests');
  if(strProps.length===0){strBox.innerHTML='<p class="muted" style="font-size:13px">No short-term rental properties. Mark a property as STR to track material participation.</p>';}
  else{strBox.innerHTML=strProps.map(function(p){
    const h=es.filter(e=>e.propertyId===p.id).reduce((s,e)=>s+e.hours,0);
    const others=Number(p.othersHours||0);
    const test500=h>=500,test100=h>=100&&h>others,pass=test500||test100;
    return '<div class="test-row"><div class="lbl">'+esc(p.name)+'<small>'+fmtH(h)+' hrs'+(single?' by '+esc(shortUser(currentUserFilter)):' (team)')+(others?(' &middot; others '+fmtH(others)+' hrs'):'')+'</small></div><div>'+
      pill(pass,pass?(test500?'500-hr test':'100-hr & most'):(h>=100?'need > others':'building'))+'</div></div>';}).join('');}
  drawCharts(es);
}
function statCard(k,v,sub,pct,color){return '<div class="card stat"><div class="k">'+k+'</div><div class="v">'+v+'</div><div class="sub">'+sub+'</div><div class="bar"><span style="width:'+pct+'%;background:var('+color+')"></span></div></div>';}
function testRow(lbl,sub,pass,val,muted){const p=muted?'<span class="pill mut"><span class="dot" style="background:currentColor"></span>n/a</span>':pill(pass,pass?'Pass':'Not met');
  return '<div class="test-row"><div class="lbl">'+lbl+'<small>'+sub+'</small></div><div style="text-align:right"><div class="muted" style="font-size:12px;margin-bottom:4px">'+val+'</div>'+p+'</div></div>';}
function pill(ok,txt){return '<span class="pill '+(ok?'ok':'no')+'"><span class="dot" style="background:currentColor"></span>'+txt+'</span>';}
function drawCharts(es){
  Object.values(charts).forEach(c=>c&&c.destroy());
  const gridC='rgba(148,163,184,.12)',tickC='#94a3b8';
  const co={plugins:{legend:{labels:{color:tickC,font:{size:11}}}},scales:{x:{ticks:{color:tickC},grid:{color:gridC}},y:{ticks:{color:tickC},grid:{color:gridC}}}};
  const months=Array(12).fill(0);es.forEach(e=>{months[new Date(e.date).getMonth()]+=e.hours;});
  charts.month=new Chart(document.getElementById('chMonth'),{type:'bar',data:{labels:['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],datasets:[{label:'Hours',data:months,backgroundColor:'#0ea5e9',borderRadius:5}]},options:Object.assign({},co,{plugins:{legend:{display:false}},maintainAspectRatio:false})});
  const cats={};es.forEach(e=>cats[e.category]=(cats[e.category]||0)+e.hours);
  const palette=['#38bdf8','#6366f1','#22c55e','#f59e0b','#ef4444','#a855f7','#14b8a6','#eab308','#ec4899','#64748b','#f97316'];
  charts.cat=new Chart(document.getElementById('chCat'),{type:'doughnut',data:{labels:Object.keys(cats),datasets:[{data:Object.values(cats),backgroundColor:palette}]},options:{maintainAspectRatio:false,plugins:{legend:{position:'right',labels:{color:tickC,font:{size:11},boxWidth:12}}}}});
  const props={};es.forEach(e=>{const p=propById(e.propertyId);const n=p?p.name:'Unassigned';props[n]=(props[n]||0)+e.hours;});
  charts.prop=new Chart(document.getElementById('chProp'),{type:'bar',data:{labels:Object.keys(props),datasets:[{label:'Hours',data:Object.values(props),backgroundColor:'#6366f1',borderRadius:5}]},options:Object.assign({},co,{indexAxis:'y',plugins:{legend:{display:false}},maintainAspectRatio:false})});
}

function renderLog(){
  const pf=document.getElementById('logPropFilter'),cf=document.getElementById('logCatFilter'),uf=document.getElementById('logUserFilter');
  pf.innerHTML='<option value="">All properties</option>'+STATE.properties.map(p=>'<option value="'+p.id+'">'+esc(p.name)+'</option>').join('');
  cf.innerHTML='<option value="">All categories</option>'+CATEGORIES.map(c=>'<option>'+c+'</option>').join('');
  const curU=uf.value;
  uf.innerHTML='<option value="">Everyone</option>'+knownUsers().map(u=>'<option value="'+esc(u)+'">'+esc(u)+'</option>').join('');
  uf.value=curU;
  applyLogFilters();
}
function applyLogFilters(){
  const q=(document.getElementById('logSearch').value||'').toLowerCase();
  const pf=document.getElementById('logPropFilter').value,cf=document.getElementById('logCatFilter').value,uf=document.getElementById('logUserFilter').value;
  let rows=entriesForYear().sort((a,b)=>b.date.localeCompare(a.date));
  if(pf)rows=rows.filter(e=>e.propertyId===pf);
  if(cf)rows=rows.filter(e=>e.category===cf);
  if(uf)rows=rows.filter(e=>e.by===uf);
  if(q)rows=rows.filter(e=>(e.activity+' '+(e.notes||'')).toLowerCase().includes(q));
  document.getElementById('logEmpty').classList.toggle('hidden',rows.length>0);
  document.getElementById('logBody').innerHTML=rows.map(function(e){const p=propById(e.propertyId);
    return '<tr><td>'+e.date+'</td><td>'+(p?esc(p.name):'<span class="muted">&mdash;</span>')+'</td>'+
      '<td><span class="tag">'+esc(e.category)+'</span></td><td><b>'+fmtH(e.hours)+'</b></td>'+
      '<td>'+esc(e.activity)+(e.notes?('<div class="muted" style="font-size:12px">'+esc(e.notes)+'</div>'):'')+'</td>'+
      '<td class="muted" style="font-size:12px">'+esc(shortUser(e.by))+(e.by===currentEmail?' (you)':'')+'</td>'+
      '<td>'+(e.attachmentPath?('<span class="att-thumb" data-att="'+esc(e.attachmentPath)+'">&#128206; view</span>'):'<span class="muted">&mdash;</span>')+'</td>'+
      '<td style="white-space:nowrap"><button class="btn ghost sm" data-edit="'+e.id+'">Edit</button></td></tr>';}).join('');
}
function renderProperties(){
  document.getElementById('propEmpty').classList.toggle('hidden',STATE.properties.length>0);
  document.getElementById('propCards').innerHTML=STATE.properties.map(function(p){
    const h=entriesForYear().filter(e=>e.propertyId===p.id).reduce((s,e)=>s+e.hours,0);
