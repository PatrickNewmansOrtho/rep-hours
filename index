<style>
  :root{--bg:#0f172a;--panel:#1e293b;--panel2:#273449;--line:#334155;--text:#e2e8f0;--muted:#94a3b8;
    --accent:#38bdf8;--accent2:#0ea5e9;--green:#22c55e;--amber:#f59e0b;--red:#ef4444;--radius:14px;}
  *{box-sizing:border-box}
  body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
       background:var(--bg);color:var(--text);font-size:15px;line-height:1.5}
  button{font-family:inherit;cursor:pointer}
  input,select,textarea{font-family:inherit;font-size:14px;background:var(--panel2);border:1px solid var(--line);
       color:var(--text);border-radius:8px;padding:9px 11px;width:100%}
  input:focus,select:focus,textarea:focus{outline:none;border-color:var(--accent)}
  label{display:block;font-size:12px;color:var(--muted);margin:0 0 5px;font-weight:600;letter-spacing:.02em}
  .btn{background:var(--accent2);color:#06121e;border:none;border-radius:8px;padding:10px 16px;font-weight:700;font-size:14px}
  .btn:hover{background:var(--accent)} .btn:disabled{opacity:.5;cursor:default}
  .btn.ghost{background:transparent;border:1px solid var(--line);color:var(--text)}
  .btn.ghost:hover{border-color:var(--accent)}
  .btn.danger{background:transparent;border:1px solid var(--red);color:#fca5a5}
  .btn.sm{padding:6px 10px;font-size:12px}
  .hidden{display:none!important}
  .row{display:flex;gap:12px;flex-wrap:wrap}
  #auth{position:fixed;inset:0;background:radial-gradient(1200px 600px at 50% -10%,#1e3a5f,#0f172a);
        display:flex;align-items:center;justify-content:center;z-index:100;padding:16px}
  .auth-card{background:var(--panel);border:1px solid var(--line);border-radius:20px;padding:34px;width:min(400px,94vw);box-shadow:0 30px 80px rgba(0,0,0,.5)}
  .auth-card h1{margin:0 0 4px;font-size:22px} .auth-card p{margin:0 0 22px;color:var(--muted);font-size:13px}
  .brand{display:flex;align-items:center;gap:10px;margin-bottom:20px}
  .brand .logo{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--accent),#6366f1);display:flex;align-items:center;justify-content:center;font-weight:800;color:#06121e}
  .auth-err{color:#fca5a5;font-size:13px;margin-top:10px;min-height:18px}
  .auth-toggle{margin-top:16px;font-size:13px;color:var(--muted);text-align:center}
  .auth-toggle a{color:var(--accent);cursor:pointer}
  header{position:sticky;top:0;background:rgba(15,23,42,.85);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);padding:12px 20px;display:flex;align-items:center;gap:16px;z-index:20}
  header .brand{margin:0}
  nav{display:flex;gap:4px;margin-left:8px;flex-wrap:wrap}
  nav button{background:transparent;border:none;color:var(--muted);padding:8px 14px;border-radius:8px;font-weight:600;font-size:14px}
  nav button.active{background:var(--panel);color:var(--text)} nav button:hover{color:var(--text)}
  header .spacer{flex:1}
  .who{font-size:12px;color:var(--muted);max-width:160px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
  main{max-width:1120px;margin:0 auto;padding:22px 20px 60px}
  .view{display:none} .view.active{display:block}
  h2.section{font-size:18px;margin:2px 0 16px}
  .card{background:var(--panel);border:1px solid var(--line);border-radius:var(--radius);padding:18px}
  .cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(230px,1fr));gap:14px}
  .stat .k{font-size:12px;color:var(--muted);font-weight:600;text-transform:uppercase;letter-spacing:.04em}
  .stat .v{font-size:30px;font-weight:800;margin:6px 0 2px}
  .stat .sub{font-size:12px;color:var(--muted)}
  .bar{height:9px;background:var(--panel2);border-radius:20px;overflow:hidden;margin-top:12px}
  .bar>span{display:block;height:100%;border-radius:20px;background:var(--accent2);transition:width .5s}
  .pill{display:inline-flex;align-items:center;gap:6px;font-size:12px;font-weight:700;padding:3px 10px;border-radius:20px}
  .pill.ok{background:rgba(34,197,94,.15);color:#4ade80} .pill.no{background:rgba(239,68,68,.15);color:#f87171}
  .pill.mut{background:var(--panel2);color:var(--muted)}
  .dot{width:8px;height:8px;border-radius:50%}
  table{width:100%;border-collapse:collapse;font-size:14px}
  th,td{text-align:left;padding:10px 12px;border-bottom:1px solid var(--line)}
  th{color:var(--muted);font-size:12px;text-transform:uppercase;letter-spacing:.03em}
  tr:hover td{background:var(--panel2)}
  .muted{color:var(--muted)}
  .toolbar{display:flex;gap:10px;align-items:end;flex-wrap:wrap;margin-bottom:16px}
  .toolbar .grow{flex:1;min-width:160px}
  .chart-wrap{position:relative;height:260px}
  .two{display:grid;grid-template-columns:1fr 1fr;gap:14px}
  @media(max-width:820px){.two{grid-template-columns:1fr}}
