  .tag.str{background:rgba(56,189,248,.15);color:var(--accent)} .tag.ltr{background:rgba(148,163,184,.15);color:var(--muted)}
  .reason{font-size:11px;padding:2px 8px;border-radius:6px;font-weight:700}
  .reason.weekly{background:rgba(56,189,248,.15);color:var(--accent)}
  .reason.manual{background:rgba(34,197,94,.15);color:#4ade80}
  .reason.exit,.reason.signout{background:rgba(245,158,11,.15);color:#fbbf24}
  .reason.auto{background:var(--panel2);color:var(--muted)}
  .reason.restore{background:rgba(239,68,68,.15);color:#f87171}
  .modal{position:fixed;inset:0;background:rgba(2,6,23,.7);display:flex;align-items:center;justify-content:center;z-index:50;padding:16px}
  .modal .box{background:var(--panel);border:1px solid var(--line);border-radius:16px;padding:22px;width:min(560px,96vw);max-height:92vh;overflow:auto}
  .modal h3{margin:0 0 16px}
  .field{margin-bottom:14px}
  .close-x{float:right;background:none;border:none;color:var(--muted);font-size:22px;line-height:1;cursor:pointer}
  .att-thumb{display:inline-flex;align-items:center;gap:6px;font-size:12px;color:var(--accent);text-decoration:none;cursor:pointer}
  .empty{text-align:center;color:var(--muted);padding:40px 10px}
  .note{font-size:12px;color:var(--muted);background:var(--panel2);border-left:3px solid var(--accent2);padding:10px 12px;border-radius:0 8px 8px 0;margin-top:6px}
  .test-row{display:flex;justify-content:space-between;align-items:center;padding:12px 0;border-bottom:1px solid var(--line)}
  .test-row:last-child{border-bottom:none}
  .test-row .lbl{font-weight:600} .test-row .lbl small{display:block;color:var(--muted);font-weight:400;font-size:12px}
  footer{color:var(--muted);font-size:12px;text-align:center;padding:20px}
  a{color:var(--accent)}
  #toast{position:fixed;bottom:20px;left:50%;transform:translateX(-50%);background:var(--panel);border:1px solid var(--line);padding:10px 16px;border-radius:10px;font-size:13px;opacity:0;transition:opacity .3s;pointer-events:none;z-index:200}
  #toast.show{opacity:1}
  #saveState{font-size:11px;color:var(--muted)}
  .config-warn{background:rgba(245,158,11,.12);border:1px solid var(--amber);color:#fcd34d;padding:14px;border-radius:12px;font-size:13px;margin-bottom:16px}
  @media print{header,nav,#yearSelect,.toolbar,footer,#fab{display:none!important}body{background:#fff;color:#000}}

  /* ---------- Mobile / touch layout ---------- */
  #fab{display:none}
  @media(max-width:760px){
    header{padding:10px 12px;gap:10px 12px;flex-wrap:wrap;padding-top:max(10px,env(safe-area-inset-top))}
    header .brand strong{display:none}
    header .spacer{display:none}
    #saveState{display:none}
    .who{order:2;margin-left:auto;max-width:150px;font-size:11px}
    #yearSelect{order:2;padding:7px 8px}
    #signOut{order:2}
    #quickAdd{display:none}                 /* replaced by the floating + button */
    nav{order:5;width:100%;margin-left:0;overflow-x:auto;flex-wrap:nowrap;-webkit-overflow-scrolling:touch;
        gap:2px;padding-bottom:2px;scrollbar-width:none}
    nav::-webkit-scrollbar{display:none}
    nav button{white-space:nowrap;flex:0 0 auto;padding:8px 12px}
    main{padding:16px 12px calc(96px + env(safe-area-inset-bottom))}
    h2.section{font-size:16px}
    .stat .v{font-size:26px}
    .card{padding:15px}
    .toolbar{gap:8px}
    .toolbar>div,.toolbar .grow{flex:1 1 140px;min-width:0}
    .toolbar button{flex:1 1 auto}
    /* dashboard top toolbar: stack heading over the controls */
    #view-dashboard>.toolbar{flex-direction:column;align-items:stretch}
    #view-dashboard>.toolbar>div{width:100%;flex-wrap:wrap}
    #view-dashboard>.toolbar select,#view-dashboard>.toolbar #cpaBtn{width:100%}
    #view-dashboard>.toolbar>div>div{flex:1 1 100%;min-width:0}
    /* tables scroll horizontally with momentum; tighten spacing */
    .card>table,section .card{ }
    th,td{padding:8px 8px;font-size:13px}
    table{min-width:560px}                  /* keep columns readable; container scrolls */
    .card:has(>table){-webkit-overflow-scrolling:touch}
    .modal{align-items:flex-end;padding:0}
    .modal .box{width:100%;max-width:100%;border-radius:16px 16px 0 0;max-height:94vh;padding:20px 18px calc(20px + env(safe-area-inset-bottom))}
  }
  /* Floating quick-log button (phones only) */
  @media(max-width:760px){
    #fab{display:flex;position:fixed;right:16px;bottom:calc(16px + env(safe-area-inset-bottom));
      width:58px;height:58px;border-radius:50%;background:var(--accent2);color:#06121e;border:none;
      align-items:center;justify-content:center;font-size:30px;font-weight:800;line-height:1;
      box-shadow:0 10px 26px rgba(0,0,0,.45);z-index:40}
    #fab:active{transform:scale(.94)}
  }
</style>
