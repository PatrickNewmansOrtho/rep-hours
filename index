    if(!name){toast('Give the property a name.');return;}
    this.disabled=true;
    const rec={id:p.id,name:name,address:document.getElementById('p_addr').value.trim(),type:document.getElementById('p_type').value,othersHours:Number(document.getElementById('p_others').value||0)};
    const ok=await saveProperty(rec);if(ok)closeModal();else this.disabled=false;
  };
  if(existing){document.getElementById('p_del').onclick=async function(){if(confirm('Delete this property? Entries stay but become unassigned.')){await deleteProperty(p.id);closeModal();}};}
}

/* ============================ CPA per-person PDF ============================ */
function openCpaModal(){
  const users=knownUsers();
  const pre=currentUserFilter||currentEmail;
  document.getElementById('modalMount').innerHTML=
   '<div class="modal"><div class="box"><button class="close-x" onclick="closeModal()">&times;</button>'+
    '<h3>CPA report (PDF)</h3>'+
    '<p class="muted" style="font-size:13px;margin-top:-8px">A one-person REPS &amp; short-term-rental hours substantiation report for the tax year, including the full itemized log.</p>'+
    '<div class="field"><label>Person</label><select id="cpa_person">'+users.map(u=>'<option value="'+esc(u)+'" '+(u===pre?'selected':'')+'>'+esc(u)+'</option>').join('')+'</select></div>'+
    '<div class="field"><label>Tax year</label><input type="number" id="cpa_year" value="'+currentYear+'" step="1"></div>'+
    '<div class="row" style="justify-content:flex-end;margin-top:8px"><button class="btn ghost" onclick="closeModal()">Cancel</button><button class="btn" id="cpa_go">Generate PDF</button></div>'+
   '</div></div>';
  document.getElementById('cpa_go').onclick=function(){
    const email=document.getElementById('cpa_person').value;
    const year=parseInt(document.getElementById('cpa_year').value,10)||currentYear;
    try{buildCpaPdf(email,year);closeModal();}
    catch(err){toast('PDF error: '+(err.message||err));}
  };
}
function buildCpaPdf(email,year){
  if(!window.jspdf||!window.jspdf.jsPDF){toast('PDF library not loaded (need internet).');return;}
  const {jsPDF}=window.jspdf;
  const doc=new jsPDF({unit:'pt',format:'letter'});
  const M=48, PW=doc.internal.pageSize.getWidth();
  const es=STATE.entries.filter(e=>new Date(e.date).getFullYear()===year && e.by===email)
                        .sort((a,b)=>a.date.localeCompare(b.date));
  const total=es.reduce((s,e)=>s+e.hours,0);
  const otherH=Number(STATE.personSettings[email+'|'+year]||0);
  const t1=total>750, t2=total>otherH&&total>0, reps=t1&&t2;
  const strProps=STATE.properties.filter(p=>p.type==='STR');

  // Header
  let y=54;
  doc.setFont('helvetica','bold');doc.setFontSize(16);
  doc.text('Real Estate Professional Status — Hours Substantiation',M,y);y+=22;
  doc.setFont('helvetica','normal');doc.setFontSize(10);doc.setTextColor(90);
  doc.text('Prepared for: '+email,M,y);y+=14;
  doc.text('Tax year: '+year+'      Generated: '+new Date().toLocaleString(),M,y);y+=14;
  doc.text('Source: contemporaneous time log maintained in REP Hours Tracker.',M,y);y+=6;
  doc.setTextColor(0);

  const money=n=>fmtH(n);
  // 1) REPS determination
  doc.autoTable({startY:y+16,margin:{left:M,right:M},styles:{fontSize:10,cellPadding:5},
    headStyles:{fillColor:[30,41,59]},
    head:[['REPS determination','Result']],
    body:[
      ['Total real estate hours logged',money(total)+' hrs'],
      ['Test 1 — more than 750 hours',(t1?'PASS':'NOT MET')+'  ('+money(total)+' hrs)'],
      ['Test 2 — more than half of total working time',(t2?'PASS':'NOT MET')+'  ('+money(total)+' RE vs '+money(otherH)+' non-RE hrs)'],
      ['Overall REPS (both tests)',reps?'LIKELY QUALIFIES':'DOES NOT QUALIFY on these hours']
    ],
    didParseCell:function(d){if(d.section==='body'&&d.column.index===1){
      const v=d.cell.raw;if(/PASS|LIKELY/.test(v))d.cell.styles.textColor=[22,120,60];
      else if(/NOT MET|DOES NOT/.test(v))d.cell.styles.textColor=[190,40,40];}}
  });
  y=doc.lastAutoTable.finalY;

  // 2) STR material participation
  if(strProps.length){
    y=sectionHeading(doc,'Short-term rental material participation',y+26,M);
    doc.autoTable({startY:y,margin:{left:M,right:M},styles:{fontSize:10,cellPadding:5},headStyles:{fillColor:[30,41,59]},
      head:[['Property','Your hours',"Others' hours",'Material participation']],
      body:strProps.map(function(p){
        const h=es.filter(e=>e.propertyId===p.id).reduce((s,e)=>s+e.hours,0);
        const o=Number(p.othersHours||0);
        const t500=h>=500,t100=h>=100&&h>o,pass=t500||t100;
        return [p.name,money(h),money(o),pass?('MET ('+(t500?'500-hr test':'100-hr & more than others')+')'):'not met'];})
    });
    y=doc.lastAutoTable.finalY;
  }

  // 3) Category breakdown
  const cats={};es.forEach(e=>cats[e.category]=(cats[e.category]||0)+e.hours);
  if(Object.keys(cats).length){
    y=sectionHeading(doc,'Hours by category',y+26,M);
    doc.autoTable({startY:y,margin:{left:M,right:M},styles:{fontSize:10,cellPadding:5},headStyles:{fillColor:[30,41,59]},
      head:[['Category','Hours','% of total']],
      body:Object.keys(cats).sort((a,b)=>cats[b]-cats[a]).map(c=>[c,money(cats[c]),total?Math.round(cats[c]/total*100)+'%':'0%'])});
    y=doc.lastAutoTable.finalY;
  }

  // 4) Monthly breakdown
  const MN=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const mo=Array(12).fill(0);es.forEach(e=>{mo[new Date(e.date).getMonth()]+=e.hours;});
  y=sectionHeading(doc,'Hours by month',y+26,M);
  doc.autoTable({startY:y,margin:{left:M,right:M},styles:{fontSize:9,cellPadding:4},headStyles:{fillColor:[30,41,59]},
    head:[MN],body:[mo.map(money)]});
  y=doc.lastAutoTable.finalY;

  // 5) Itemized log
  y=sectionHeading(doc,'Itemized time log ('+es.length+' entries)',y+26,M);
  doc.autoTable({startY:y,margin:{left:M,right:M},styles:{fontSize:8,cellPadding:3,overflow:'linebreak'},
    headStyles:{fillColor:[30,41,59]},
    columnStyles:{0:{cellWidth:56},1:{cellWidth:90},2:{cellWidth:90},3:{cellWidth:34,halign:'right'},5:{cellWidth:48,halign:'center'}},
    head:[['Date','Property','Category','Hrs','Activity','Evid.']],
    body:es.map(function(e){const p=propById(e.propertyId);
      return [e.date,p?p.name:'—',e.category,money(e.hours),(e.activity||'')+(e.notes?(' — '+e.notes):''),e.attachmentPath?'Yes':'—'];}),
    foot:[[{content:'Total',colSpan:3,styles:{halign:'right',fontStyle:'bold'}},{content:money(total),styles:{halign:'right',fontStyle:'bold'}},'','']],
    footStyles:{fillColor:[39,52,73]}});

  // Footer on every page
  const pages=doc.getNumberOfPages();
  for(let i=1;i<=pages;i++){doc.setPage(i);
    doc.setFontSize(8);doc.setTextColor(130);
    doc.text('Record-keeping report — not tax advice. Contemporaneous log maintained in REP Hours Tracker.',M,doc.internal.pageSize.getHeight()-24);
    doc.text('Page '+i+' of '+pages,PW-M-40,doc.internal.pageSize.getHeight()-24);}
  doc.save('REPS-summary-'+shortUser(email)+'-'+year+'.pdf');
}
function sectionHeading(doc,text,startY,M){
  const bottom=doc.internal.pageSize.getHeight()-70;
  if(startY>bottom){doc.addPage();startY=54;}
  doc.setFont('helvetica','bold');doc.setFontSize(12);doc.setTextColor(0);
  doc.text(text,M,startY);doc.setFont('helvetica','normal');
  return startY+8;
}

/* ============================ Export ============================ */
function exportCSV(){
  const es=entriesForYear().sort((a,b)=>a.date.localeCompare(b.date));
  const rows=[['Date','Property','Type','Category','Hours','Activity','Notes','Logged by','Has evidence']];
  es.forEach(function(e){const p=propById(e.propertyId);rows.push([e.date,p?p.name:'',p?p.type:'',e.category,e.hours,e.activity,e.notes||'',e.by||'',e.attachmentPath?'Yes':'No']);});
  const csv=rows.map(r=>r.map(c=>'"'+String(c).replace(/"/g,'""')+'"').join(',')).join('\n');
  const u=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));const a=document.createElement('a');
  a.href=u;a.download='rep-hours-'+currentYear+'.csv';a.click();URL.revokeObjectURL(u);
}

